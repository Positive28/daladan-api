        "/profile/ads": {
            "post": {
                "tags": [
                    "Ads"
                ],
                "summary": "Profil sahifasidan e'lon yaratish",
                "operationId": "db1c9c5dd9d4fef529068d99d6edc72a",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "category_id",
                                    "subcategory_id",
                                    "title",
                                    "price",
                                    "quantity"
                                ],
                                "properties": {
                                    "category_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "subcategory_id": {
                                        "type": "integer",
                                        "example": 10
                                    },
                                    "district": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "title": {
                                        "type": "string",
                                        "example": "Olma sotiladi"
                                    },
                                    "description": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "price": {
                                        "type": "number",
                                        "example": 15000
                                    },
                                    "quantity": {
                                        "type": "number",
                                        "example": 100
                                    },
                                    "quantity_description": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "unit": {
                                        "type": "string",
                                        "example": "kg"
                                    },
                                    "delivery_info": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "media[]": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "format": "binary"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "E'lon yaratildi"
                    },
                    "422": {
                        "description": "Validatsiya xatosi yoki profil manzili to'ldirilmagan"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },

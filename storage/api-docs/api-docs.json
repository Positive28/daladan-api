                                    },
                                    "subcategory_id": {
                                        "type": "integer",
                                        "example": 10
                                    },
                                    "district": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "title": {
                                        "type": "string",
                                        "example": "Yangi sarlavha"

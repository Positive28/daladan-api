                                    "description": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "price": {
                                        "type": "number",
                                        "example": 16000
                                    },
                                    "quantity": {
                                        "type": "number",
                                        "example": 80
                                    },
                                    "quantity_description": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "unit": {
